{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "SLO Status Overview",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "count(slo_compliance_ratio >= slo_target) or vector(0)",
          "legendFormat": "SLOs Meeting Target"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 6 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "SLO Compliance — Plex Availability",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_compliance_ratio{service=\"plex\", objective=\"availability\"}",
          "legendFormat": "Plex"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "SLO Compliance — NAS Availability",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_compliance_ratio{service=\"nas\", objective=\"availability\"}",
          "legendFormat": "NAS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "yellow", "value": 0.999 },
              { "color": "green", "value": 0.9999 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "SLO Compliance — DNS Latency p99",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_compliance_ratio{service=\"dns\", objective=\"latency_p99\"}",
          "legendFormat": "DNS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "SLO Compliance — Proxmox Cluster",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_compliance_ratio{service=\"proxmox\", objective=\"availability\"}",
          "legendFormat": "Proxmox"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "yellow", "value": 0.999 },
              { "color": "green", "value": 0.9999 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "SLO Compliance — Immich",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_compliance_ratio{service=\"immich\", objective=\"availability\"}",
          "legendFormat": "Immich"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "SLO Compliance — Monitoring Stack",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_compliance_ratio{service=\"monitoring\", objective=\"availability\"}",
          "legendFormat": "Monitoring"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "Burn Rate — All Services (1h window)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_burn_rate{window=\"1h\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Burn Rate — All Services (24h window)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_burn_rate{window=\"24h\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Error Budget Remaining",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_error_budget_remaining_ratio",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "title": "SLO Compliance Over Time (30d)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_compliance_ratio{window=\"30d\"}",
          "legendFormat": "{{service}} — {{objective}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0.9,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "pointSize": 3,
            "showPoints": "auto"
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "Active Incidents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 32 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_active_incidents or vector(0)",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "title": "Mean Time to Resolve (minutes)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 32 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_mean_time_to_resolve_minutes or vector(0)",
          "legendFormat": "MTTResolve"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "m"
        }
      }
    },
    {
      "title": "Safety Gate Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 32 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "slo_safety_gate_blocked or vector(0)",
          "legendFormat": "Blocked"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "CLEAR", "color": "green" } }, "type": "value" },
            { "options": { "1": { "text": "BLOCKED", "color": "red" } }, "type": "value" }
          ]
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["slo", "reliability", "homelab"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SLO Status Dashboard",
  "uid": "slo-status-homelab",
  "version": 1
}
